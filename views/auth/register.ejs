<%- include('../partials/header') %>
<h1>Register</h1>

<% if (errors && errors.length) { %>
  <ul style="color:red;">
    <% errors.forEach(err => { %>
      <li><%= err.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form action="/auth/register" method="POST">
  <div>
    <label>Name</label>
    <input name="name" value="<%= old && old.name ? old.name : '' %>" required>
  </div>
  <div>
    <label>Email</label>
    <input name="email" value="<%= old && old.email ? old.email : '' %>" required>
  </div>
  <div>
    <label>Password</label>
    <input name="password" type="password" required>
  </div>
  <button type="submit">Register</button>
</form>
<a href="/auth/login">Login</a>
