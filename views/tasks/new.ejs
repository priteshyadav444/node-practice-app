<%- include('../partials/header') %>
<h1>New Task</h1>

<% if (errors && errors.length) { %>
  <ul style="color:red;">
    <% errors.forEach(err => { %>
      <li><%= err.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form action="/tasks" method="POST">
  <div>
    <label>Title</label>
    <input name="title" value="<%= old && old.title ? old.title : '' %>" required>
  </div>
  <div>
    <label>Description</label>
    <textarea name="description"><%= old && old.description ? old.description : '' %></textarea>
  </div>
  <button type="submit">Create</button>
</form>
<a href="/tasks">Back</a>